# Trim CI/internal noise from `git archive` output (incl. GitHub's auto
# "Source code" release archives), per the org release-artifact standard.
# Note: directory patterns use the /** form — bare `dir/` patterns do not
# recurse reliably for export-ignore.
.github/** export-ignore
tests/** export-ignore
.gitattributes export-ignore
.gitignore export-ignore
src/__tests__ export-ignore
src/__tests__/** export-ignore
vitest.config.ts export-ignore
