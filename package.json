{
  "name": "@cinatra-ai/openai-connector",
  "version": "0.1.8",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "src",
    "!src/__tests__"
  ,
    "cinatra"],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./register": "./src/register.ts",
    "./deps": "./src/deps.ts",
    "./actions": "./src/actions.ts",
    "./log-directory": "./src/log-directory.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest",
    "lint": "eslint . --no-inline-config"
  },
  "dependencies": {
    "@openai/agents": "^0.11.4",
    "openai": "^6.38.0"
  },
  "peerDependencies": {
    "@cinatra-ai/sdk-extensions": "*",
    "@cinatra-ai/sdk-ui": "*"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    },
    "@cinatra-ai/sdk-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "10.4.1",
    "typescript": "5.9.3"
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "connector",
    "vendor": {
      "key": "cinatra-ai",
      "name": "Cinatra"
    },
    "displayName": "OpenAI",
    "dependencies": [],
    "serverEntry": "./register",
    "requestedHostPorts": [
      "capabilities",
      "ui"
    ],
    "sdkAbiRange": "^2",
    "providerConfigKey": "cinatra-openai",
    "uiSurface": "schema-config",
    "configSchema": {
      "title": "OpenAI",
      "hydrateAction": "currentConfig",
      "description": "Connect OpenAI through Nango for Cinatra's model-backed workflows, and configure the sandboxed shell-skill executor policy. Only workspace admins can change these settings.",
      "fields": [
        {
          "kind": "banner",
          "label": "Result",
          "variants": [
            {
              "name": "saved",
              "tone": "success",
              "message": "OpenAI settings saved."
            },
            {
              "name": "cleared",
              "tone": "warning",
              "message": "The saved OpenAI API key was removed."
            },
            {
              "name": "error",
              "tone": "destructive",
              "message": "Something went wrong saving the OpenAI settings."
            }
          ]
        },
        {
          "kind": "status-probe",
          "label": "Connection",
          "actionId": "connectionStatus",
          "description": "Check that the saved OpenAI API key resolves and has been validated."
        },
        {
          "kind": "secret",
          "key": "apiKey",
          "label": "API key",
          "description": "Paste your OpenAI API key to connect. It is validated before it is saved. Leave blank to keep the current saved key; use Disconnect to remove it."
        },
        {
          "kind": "text",
          "key": "projectId",
          "label": "Project ID (optional)",
          "description": "Scope API usage to a specific OpenAI project. Leave blank to keep the current saved value."
        },
        {
          "kind": "text",
          "key": "organizationId",
          "label": "Organization ID (optional)",
          "description": "Scope to a specific OpenAI organization. Leave blank to keep the current saved value."
        },
        {
          "kind": "select",
          "key": "serviceTier",
          "label": "Service tier",
          "defaultValue": "default",
          "options": [
            {
              "value": "default",
              "label": "Standard"
            },
            {
              "value": "flex",
              "label": "Flex"
            },
            {
              "value": "priority",
              "label": "Priority"
            }
          ]
        },
        {
          "kind": "dynamic-select-options",
          "key": "defaultModel",
          "label": "Default model",
          "optionsAction": "listModels",
          "defaultValue": "gpt-5.5",
          "placeholder": "Save a working key first, then choose the default model.",
          "description": "Mini and nano models are excluded. Cinatra's web scraping and data extraction requires full-size models — smaller models skip direct page visits and fall back to keyword searches, producing incomplete results."
        },
        {
          "kind": "named-action",
          "label": "Connect",
          "actionId": "saveConnection",
          "role": "connect"
        },
        {
          "kind": "named-action",
          "label": "Disconnect",
          "actionId": "clearConnection",
          "role": "disconnect"
        }
      ],
      "tabs": [
        {
          "id": "shell",
          "label": "Local shell",
          "fields": [
            {
              "kind": "banner",
              "label": "Result",
              "variants": [
                {
                  "name": "saved",
                  "tone": "success",
                  "message": "OpenAI settings saved."
                },
                {
                  "name": "cleared",
                  "tone": "warning",
                  "message": "The saved OpenAI API key was removed."
                },
                {
                  "name": "error",
                  "tone": "destructive",
                  "message": "Something went wrong saving the OpenAI settings."
                }
              ]
            },
            {
              "kind": "boolean",
              "key": "enabled",
              "label": "Enable sandboxed shell architecture",
              "defaultValue": true,
              "description": "When enabled, the package can prepare shell tool payloads plus the sandbox policy your production executor should apply."
            },
            {
              "kind": "text",
              "key": "runnerLabel",
              "label": "Sandbox runner label"
            },
            {
              "kind": "text",
              "key": "containerImage",
              "label": "Container image"
            },
            {
              "kind": "text",
              "key": "containerWorkspacePath",
              "label": "Container workspace path"
            },
            {
              "kind": "text",
              "key": "containerCpuLimit",
              "label": "Container CPU limit"
            },
            {
              "kind": "text",
              "key": "containerMemoryLimit",
              "label": "Container memory limit"
            },
            {
              "kind": "number",
              "key": "containerPidsLimit",
              "label": "Container PID limit",
              "min": 16,
              "max": 2048,
              "defaultValue": 128
            },
            {
              "kind": "number",
              "key": "maxExecutionSeconds",
              "label": "Max execution seconds",
              "min": 5,
              "max": 600,
              "defaultValue": 30
            },
            {
              "kind": "number",
              "key": "maxOutputKilobytes",
              "label": "Max output KB",
              "min": 16,
              "max": 4096,
              "defaultValue": 256
            },
            {
              "kind": "number",
              "key": "maxFileWriteKilobytes",
              "label": "Max file write KB",
              "min": 16,
              "max": 4096,
              "defaultValue": 256
            },
            {
              "kind": "boolean",
              "key": "allowNetwork",
              "label": "Allow outbound network access",
              "defaultValue": false,
              "description": "Default stays off. Only enable this when your executor also enforces the allowed-host rules below."
            },
            {
              "kind": "boolean",
              "key": "auditLogsEnabled",
              "label": "Require executor audit logs",
              "defaultValue": true,
              "description": "Signals that shell_call and shell_call_output events must be preserved for auditing."
            },
            {
              "kind": "free-list",
              "key": "readRoots",
              "label": "Readable roots",
              "itemLabel": "path",
              "placeholder": "/workspace"
            },
            {
              "kind": "free-list",
              "key": "writeRoots",
              "label": "Writable roots",
              "itemLabel": "path",
              "placeholder": "/workspace/tmp"
            },
            {
              "kind": "free-list",
              "key": "allowedCommandPrefixes",
              "label": "Allowed command prefixes",
              "itemLabel": "prefix",
              "placeholder": "ls"
            },
            {
              "kind": "free-list",
              "key": "blockedCommandPrefixes",
              "label": "Blocked command prefixes",
              "itemLabel": "prefix",
              "placeholder": "rm"
            },
            {
              "kind": "free-list",
              "key": "allowedHosts",
              "label": "Allowed outbound hosts",
              "itemLabel": "host",
              "placeholder": "api.example.com"
            },
            {
              "kind": "named-action",
              "label": "Save skills administration",
              "actionId": "saveSkillsSettings"
            }
          ]
        },
        {
          "id": "help",
          "label": "Help",
          "fields": [
            {
              "kind": "advisory",
              "label": "OpenAI setup",
              "tone": "info",
              "probeActionId": "connectionStatus",
              "whenReady": "OpenAI is connected. Use the Setup tab to update your API key, Project ID, Organization ID, service tier, or default model — mini and nano models are excluded from the picker because Cinatra's web scraping and data extraction requires full-size models. Use the Local shell tab to configure the optional sandboxed shell tool for agents that need to run commands in an isolated container: the container image, resource limits (CPU, memory, PID count, execution time, output size), which commands and filesystem paths are allowed, and whether outbound network access is permitted.",
              "whenNotReady": "Not connected yet. On the Setup tab, paste your OpenAI API key (Project ID and Organization ID are optional scoping), choose a service tier and default model, then click Connect — the key is validated against the OpenAI API before it is stored and is never shown again. Once connected, use the Local shell tab to turn on the sandboxed shell tool for agents that need to run commands in an isolated container.",
              "description": "Read-only setup guidance — nothing on this tab is saved. Only workspace admins can change these settings."
            }
          ]
        }
      ]
    },
    "consumes": []
  }
}
